# === Server ===
PORT=3100
DATABASE_PATH=./data/dashboard.db

# === Display / Monitoring (optional) ===
# Heading shown over the website-analytics column (build-time, client-visible).
NEXT_PUBLIC_SITE_NAME=Website
# Optional systemd --user unit whose health to show in the system bar
# (e.g. another app running on the same box). Leave blank to omit.
MONITOR_SERVICE=
MONITOR_SERVICE_LABEL=

# === YouTube (free, API key only) ===
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# === Apify (Instagram / TikTok / X follower counts) ===
# Full run-sync-get-dataset-items endpoint URL with ?token=... appended,
# e.g. https://api.apify.com/v2/acts/<actor>/run-sync-get-dataset-items?token=xxx
APIFY_API_TOKEN=
# Usernames WITHOUT the @ prefix
INSTAGRAM_USERNAME=
TIKTOK_USERNAME=
TWITTER_USERNAME=

# === Reddit (OAuth — create a "script" app at https://www.reddit.com/prefs/apps) ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=

# === Stripe (restricted read-only key) ===
STRIPE_SECRET_KEY=

# === Vercel Web Analytics ===
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
