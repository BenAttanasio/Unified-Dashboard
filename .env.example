# === Server ===
PORT=3100
DATABASE_PATH=./data/dashboard.db

# === Display / Monitoring (optional) ===
# Heading shown over the website-analytics column (build-time, client-visible).
NEXT_PUBLIC_SITE_NAME=Website
# Optional systemd --user unit whose health to show in the system bar
# (e.g. another app running on the same box). Leave blank to omit.
MONITOR_SERVICE=
MONITOR_SERVICE_LABEL=

# === YouTube (free, API key only) ===
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# === Apify (Instagram / TikTok / X followers) ===
# Each APIFY_*_API_ENDPOINT below is a FULL run-sync-get-dataset-items endpoint
# URL with the ?token=... appended (the token, not just a bare key), e.g.
#   https://api.apify.com/v2/acts/<actor>/run-sync-get-dataset-items?token=xxx
# They share one Apify account, so the cost tracker reads the token from any of them.
#
# Followers scraper (IG / TikTok / X) — k1ra/social-media-followers-scraper:
APIFY_SOCIAL_API_ENDPOINT=
# Usernames WITHOUT the @ prefix
INSTAGRAM_USERNAME=
TIKTOK_USERNAME=
TWITTER_USERNAME=

# TikTok total LIKES (OPTIONAL, extra Apify cost ~per run). Separate TikTok
# profile-scraper actor that returns the profile's total likes/hearts. Reuses
# TIKTOK_USERNAME for the handle. Leave blank to disable (row shows "Not
# configured", zero API calls). Adds recurring spend against the $5/mo cap.
APIFY_TIKTOK_API_ENDPOINT=

# Skool community MEMBERS (OPTIONAL, ~$1/mo Apify cost at a few polls/day).
# Actor: gordian/skool-group-scraper — pay-per-result ($8/1k results, NOT a
# monthly rental) and takes a DIRECT group slug/URL. (Avoid louisdeconinck/
# skool-scraper: $19/mo rental.) Leave blank to disable.
APIFY_SKOOL_API_ENDPOINT=
# Skool group slug (e.g. ai-mastery-human-5176) or full https://www.skool.com/... URL
SKOOL_GROUP=

# === Stripe (restricted read-only key) ===
STRIPE_SECRET_KEY=

# === Vercel Web Analytics (LEGACY — internal endpoint now 404s; kept for reference) ===
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# === First-party website analytics (benattanasio.com /api/stats) ===
# Replaces the dead Vercel internal API. Serves visitors, CTA clicks/CTR, bounce.
# Full URL to the stats endpoint, and the shared secret it checks (?token=).
SITE_STATS_URL=https://benattanasio.com/api/stats
SITE_STATS_TOKEN=

# === Home location (weather rain forecast) ===
# The Open-Meteo forecast (24h hourly + 7-day daily rain chance) is FREE and keyless.
# Set your own coordinates here (example below is generic downtown Austin; code falls
# back to it if unset). Keep your real home coords in .env only — this repo is public,
# so don't commit a precise home location.
# HOME_LAT=30.2672
# HOME_LON=-97.7431
# HOME_TZ=America/Chicago
